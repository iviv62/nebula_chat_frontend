{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test tests/**/*.test.ts",
    "lint": "eslint \"src/**/*.{ts,tsx,js,jsx}\" --quiet",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,scss,html}'",
    "prepare": "husky"
  },
  "dependencies": {
    "@lit-labs/router": "^0.1.4",
    "firebase": "^11.0.2",
    "lit": "^3.3.2",
    "zustand-lit": "^2.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.9"
  },
   "lint-staged": {
    "frontend/**/*.{ts,js,scss,html,json}": [
      "prettier --write"
    ]
  }
}
